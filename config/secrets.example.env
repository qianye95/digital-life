# =============================================================================
# 数字生命 - 密钥与环境变量模板
# =============================================================================
# 用法:cp config/secrets.example.env config/secrets.env,然后填下面 [必填] 段。
# config/secrets.env 已被 .gitignore 忽略,不会泄露。
#
# 配置优先级:环境变量 > config/secrets.env > config/local.yaml > 代码默认值
# =============================================================================

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ [必填] 不填无法启动                                                        │
# └─────────────────────────────────────────────────────────────────────────┘

# ———— 1. 当前运行的实例 ————————————————————————————————————————————————————
# init_instance.py 会生成 UUID;把生成的 UUID 填到这里指定"当前实例"。
# 多实例网关会扫描 apps/*/config/app.yaml 启动所有 active=true 的实例,
# 这里决定的只是"当前进程主实例"——通常填你最近 init 的那个,或照 README
# 的指引填任意实例 UUID。
DIGITAL_LIFE_INSTANCE_ID=
DIGITAL_LIFE_DISPLAY_NAME=

# ———— 2. LLM API Key（任意 OpenAI 兼容模型）—————————————————————————————
# 默认 GLM（智谱）：https://open.bigmodel.cn/ 控制台 → API Keys
# 也可填 DeepSeek / OpenAI / 其他 OpenAI 兼容 API 的 key。
# 实际使用的 model / base_url 在 apps/<id>/config/app.yaml 的 model 段配置。
# 旧名 GLM_API_KEY 仍兼容读取，这里用新名 LLM_API_KEY。
LLM_API_KEY=

# ———— 3. 飞书应用凭证(全局兜底,多实例请改用实例镜像) ————————————————————————
# 仅首次启动用:_ensure_default_instance() 会把这里的凭证 bootstrap 到一个
# 新建的 Zero 实例。多实例场景请在 apps/<id>/config/app.yaml(messenger.app_id)和
# apps/<id>/config/secrets.env(FEISHU_APP_SECRET / LLM_API_KEY)里按实例配置。
# 在 https://open.feishu.cn/app 新建一个"自建应用"后,
# "凭证与基础信息"里拿 App ID 和 App Secret
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ———— 4. 员工控制台访问 Key ————————————————————————————————————————————————
# 员工控制台需要 API_SERVER_KEY 才能访问。任意字符串都可以,
# 但务必改成你自己的(默认 change-me 会被脚本警告)
API_SERVER_KEY=change-me


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ [可选] 不改也能跑,改了才覆盖默认值。取消注释即生效                          │
# └─────────────────────────────────────────────────────────────────────────┘

# ———— 实例 runtime adapter ————————————————————————————————————————————————
# 默认 l4(自托管)。其他值(如 hermes)用于对接外部调度器,通常不需要改。
# DIGITAL_LIFE_RUNTIME_PROVIDER=l4

# ———— 模型配置(默认值已可用) ——————————————————————————————————————————————
# DIGITAL_LIFE_MODEL=glm-5.1
# DIGITAL_LIFE_PROVIDER=glm
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 摘要/压缩模型 — 上下文超长时用便宜模型写摘要
# DIGITAL_LIFE_SUMMARY_MODEL=glm-4.7-flash
# DIGITAL_LIFE_SUMMARY_PROVIDER=custom

# 智能路由 — 简单消息走便宜模型省成本
# DIGITAL_LIFE_SMART_ROUTING=true
# DIGITAL_LIFE_CHEAP_MODEL=glm-4.7-flash
# DIGITAL_LIFE_CHEAP_PROVIDER=custom

# 备用模型(火山引擎方舟)— 想分桶用第二家才需要
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# ———— 飞书连接参数 ——————————————————————————————————————————————————————
# FEISHU_DOMAIN=https://open.feishu.cn           # 国内开放平台(默认);国际版改 https://open.larksuite.com
# 注:domains 和 connection mode 之类已迁移到实例 app.yaml 的 messenger 段;
#     FEISHU_ALLOWED_USERS / FEISHU_HOME_CHANNEL 已停用 —— 出站发送不再偷读,
#     改由模型 express_to_human 时显式指定 chat_id,避免跨实例串味。

# ———— L4 调度参数 ————————————————————————————————————————————————————————
# HERMES_L4_DIRECT=true                            # 飞书消息直通实例(不走 gateway 中转)
# L4_TICK_INTERVAL=60                              # cron tick 间隔(秒)
# L4_HEARTBEAT_HOURS=3                             # 心跳兜底唤醒间隔(小时)

# ———— 生命维度(Vitals)调参 ——————————————————————————————————————————————
# VITALS_DECAY_SATIETY=1.0
# VITALS_DECAY_MOOD=0.5
# VITALS_DECAY_HYGIENE=0.3
# VITALS_DECAY_BOND=0.2
# VITALS_DECAY_ENERGY=30                           # 每小时消耗(数字员工活着的"代谢")
# VITALS_ENERGY_RECOVERY=15                        # 睡眠时每小时恢复
# VITALS_AWAKE_DRAIN=5
# VITALS_COST_PER_THOUGHT=3
# VITALS_COST_PER_ACTION=2
# VITALS_SLEEP_THRESHOLD=40                        # 精力低于此值 → 自动 sleep
# VITALS_NIGHT_DRAIN_START=21.5                    # 夜晚加速消耗起点(避免数字员工半夜活跃)
# VITALS_NIGHT_DRAIN_HOUR=8
# VITALS_BOREDOM_ENERGY_THRESHOLD=90
# VITALS_BOREDOM_IDLE_HOURS=1.5                    # 空闲超过此时长 + 精力充足 → 触发主动探索
# DEBUG_ENERGY_RECOVERY_AMOUNT=30

# ———— 终端 & 浏览器工具(执行代码/抓网页)—————————

# ———— 终端 & 浏览器工具(执行代码/抓网页)——————————————
# web/terminal 工具默认不启用,需要自建 Modal / Browserbase 账号
# TERMINAL_MODAL_IMAGE=nikolaik/python-nodejs:python3.11-nodejs20
# TERMINAL_TIMEOUT=60
# TERMINAL_LIFETIME_SECONDS=300
# BROWSERBASE_PROXIES=true
# BROWSERBASE_ADVANCED_STEALTH=false
# BROWSER_SESSION_TIMEOUT=300
# BROWSER_INACTIVITY_TIMEOUT=120

# ———— 调试开关 ————————————————————————————————————————————————
# WEB_TOOLS_DEBUG=false
# VISION_TOOLS_DEBUG=false
# MOA_TOOLS_DEBUG=false
# IMAGE_TOOLS_DEBUG=false
