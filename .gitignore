# === 敏感文件 ===
.env
auth.json
config.yaml
config/secrets.env
config/local.yaml
config/*.bak*
*.bak
*.bak.*

# === 实例 ===
# apps/<UUID>/ 是各实例的私有目录（含飞书凭据、人设、运行时数据）。
# 实例由 scripts/init_instance.py 从 config/templates/ 复制模板生成。
apps/*/
!apps/.gitkeep

# === 运行时数据 ===
*.db
*.db-shm
*.db-wal
sessions/
logs/
audio_cache/
cache/
__pycache__/
*.py[cod]
*.egg-info/

# === L4 运行时 ===
runtime/
var/
data/
backups/
# 实例级密钥
apps/*/config/secrets.env
# 实例私有目录（含飞书凭据、人设、运行时数据）
apps/*/
!apps/.gitkeep
# 项目目录是运行时由实例/用户创建的，不入 git
projects/*/
!projects/.gitkeep
# 共享空间同理——实例运行时生成
shared/skills/*/
!shared/skills/.gitkeep
shared/tools/*/
!shared/tools/.gitkeep
shared/capabilities/*/
!shared/capabilities/.gitkeep
# docs 只保留设计主文档 + showcase 实录 + operations 运维手册，其余过程文档不入 git
docs/*
!docs/.gitkeep
!docs/design/
docs/design/*
!docs/design/.gitkeep
!docs/design/digital-life-system-design.md
!docs/showcase/
!docs/showcase/.gitkeep
!docs/showcase/multi-instance-trading-2026-06.md
!docs/showcase/how-to-play.zh.md
!docs/operations/
# scripts/ 与 tests/ 不入版本控制（运行前/测试均为本地工作目录）
scripts/
tests/
config/local.yaml
config/secrets.env
configs/local.yaml
configs/secrets.env
backups/

